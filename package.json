{
  "name": "owlerlay",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"src-tauri/templates/**/*.j2\"",
    "format:check": "prettier --check \"src/**/*.{ts,svelte,css}\" \"src-tauri/templates/**/*.j2\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/spline-sans-mono": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@types/qrcode": "^1.5.5",
    "@fontsource-variable/quicksand": "^5.2.10",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "prettier": "^3.8.1",
    "prettier-plugin-jinja-template": "^2.1.0",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
