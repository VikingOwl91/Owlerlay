/* Per-widget config, applied on top of the structural rules in
   browsersource.html.j2. Every value here maps to a control-UI option. */
#countdown-{{ c.id }} {
    background-color: {{ c.background }};
    border: {{ c.border }};
    border-radius: {{ c.border_radius }}px;
    padding: 1rem 2rem;
    {% if c.backdrop_filter %}
    backdrop-filter: blur(8px);
    {% endif %}
    {% if c.box_shadow %}
    box-shadow: {{ c.box_shadow }};
    {% endif %}
}
#timer-{{ c.id }} {
    font-family: {{ c.font_family }};
    font-size: {{ c.font_size }}rem;
    color: {{ c.text_color }};
}
#icon-{{ c.id }} {
    width: {{ c.icon_size }};
    height: {{ c.icon_size }};
}
#divider-{{ c.id }} {
    background-color: {{ c.divider_color }};
}
#progress-{{ c.id }} {
    background-color: {{ c.bar_bg }};
}
#progress-inner-{{ c.id }} {
    background-color: {{ c.bar_fg }};
}
